{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "ignoreDeprecations": "6.0",
    "types": ["node"],
    "rootDir": "src",
    "outDir": "dist-electron"
  },
  "include": ["src/main", "src/preload", "src/db", "src/services", "src/shared"]
}
